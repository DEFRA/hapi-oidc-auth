{% extends 'layouts/page.njk' %}

{% from "govuk/components/summary-list/macro.njk" import govukSummaryList %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/tag/macro.njk" import govukTag %}

{% block content %}
  {{ appHeading({
    text: heading,
    caption: session.name
  }) }}

  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">

      {{ govukSummaryList({
        rows: [
          { key: { text: t.keyName }, value: { text: session.name } },
          { key: { text: t.keyEmail }, value: { text: session.email } },
          { key: { text: t.keyRole }, value: { text: session.roleLabel or session.role } },
          { key: { text: t.keyProvider }, value: { text: session.provider } },
          { key: { text: t.keyMode }, value: { text: session.mode } }
        ],
        attributes: { "data-testid": "account-summary" }
      }) }}

      <h2 class="govuk-heading-m">{{ t.organisationsHeading }}</h2>
      {% if session.organisations.length %}
        <ul class="govuk-list govuk-list--bullet" data-testid="account-organisations">
          {% for org in session.organisations %}
            <li>
              {{ org.organisationName or org.organisationId }}
              {% if org.relationshipId == session.organisationId %}{{ govukTag({ text: t.currentTag, classes: "govuk-tag--green" }) }}{% endif %}
            </li>
          {% endfor %}
        </ul>
      {% else %}
        <p class="govuk-body" data-testid="account-organisations">{{ t.noOrganisations }}</p>
      {% endif %}

      <h2 class="govuk-heading-m">{{ t.permissionsHeading }}</h2>
      <ul class="govuk-list govuk-list--bullet" data-testid="account-scope">
        {% for entry in session.scope %}
          <li>{{ entry }}</li>
        {% endfor %}
      </ul>

      {{ govukButton({
        text: t.signOutButton,
        href: "/auth/sign-out",
        classes: "govuk-button--secondary",
        attributes: { "data-testid": "account-sign-out" }
      }) }}

    </div>
  </div>

{% endblock %}
