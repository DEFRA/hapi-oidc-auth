{% extends 'layouts/page.njk' %}

{% from "govuk/components/notification-banner/macro.njk" import govukNotificationBanner %}

{% block content %}
  {{ appHeading({
    text: heading,
    caption: t.caption
  }) }}

  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">

      {% if authError == 'auth-required' %}
        {{ govukNotificationBanner({
          text: shared.authRequired,
          type: "important"
        }) }}
      {% endif %}

      <p class="govuk-body">{{ t.intro }}</p>
      <ul class="govuk-list govuk-list--bullet">
        <li>
          <a class="govuk-link" href="/auth/defra-id/sign-in" data-testid="choose-applicant">{{ t.applicantLinkText }}</a>
          {{ t.applicantHint }}
        </li>
        <li>
          <a class="govuk-link" href="/auth/entra/sign-in" data-testid="choose-case-officer">{{ t.caseOfficerLinkText }}</a>
          {{ t.caseOfficerHint }}
        </li>
      </ul>

    </div>
  </div>

{% endblock %}
